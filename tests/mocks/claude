#!/usr/bin/env bash
# Mock claude CLI for volley tests.
#
# Role detection mirrors how volley.sh invokes the real binary: the planner
# call carries `--permission-mode acceptEdits`; the critic call does not.
# Behavior is scripted via:
#   MOCK_STATE    (required) dir for call counters and captured prompts
#   MOCK_VERDICTS space-separated critic script, one token per critic call,
#                 last token repeats: APPROVE | APPROVE_REMARKS | REVISE | NONE
# The critic reply goes to stdout (volley captures claude critiques there).
set -euo pipefail

if [[ "${1:-}" == "--version" ]]; then
  echo "mock-claude 1.2.3"
  exit 0
fi

: "${MOCK_STATE:?MOCK_STATE dir must be set}"
mkdir -p "$MOCK_STATE"

prompt=""
planner=0
args=("$@")
for (( i=0; i<$#; i++ )); do
  case "${args[i]}" in
    -p) prompt="${args[i+1]:-}" ;;
    --permission-mode) [[ "${args[i+1]:-}" == "acceptEdits" ]] && planner=1 ;;
  esac
done

bump() { # bump <counter-name> -> new count on stdout
  local n
  n=$(( $(cat "$MOCK_STATE/$1" 2>/dev/null || echo 0) + 1 ))
  echo "$n" >"$MOCK_STATE/$1"
  echo "$n"
}

if (( planner )); then
  n="$(bump planner-calls)"
  printf '%s' "$prompt" >"$MOCK_STATE/planner-claude-$(printf '%02d' "$n").prompt"
  printf '%s\n' "$@" >"$MOCK_STATE/planner-claude-$(printf '%02d' "$n").argv"
  if [[ ! -f SPEC.md ]]; then
    cat >SPEC.md <<'EOF'
# Mock spec

Goals: satisfy the mock brief.
EOF
  else
    echo "- mock revision entry (planner call $n)" >>SPEC.md
  fi
  response_path="$(printf '%s' "$prompt" | grep -Eo 'rounds/r[0-9][0-9]\.(closing-)?response\.md' | head -1 || true)"
  if [[ -n "$response_path" ]]; then
    mkdir -p "$(dirname "$response_path")"
    echo "1. fixed: mock response entry (planner call $n)" >"$response_path"
  fi
  echo "mock claude planner: call $n done"
  exit 0
fi

n="$(bump critic-calls)"
printf '%s' "$prompt" >"$MOCK_STATE/critic-claude-$(printf '%02d' "$n").prompt"
printf '%s\n' "$@" >"$MOCK_STATE/critic-claude-$(printf '%02d' "$n").argv"
verdicts=(${MOCK_VERDICTS:-APPROVE})
idx=$(( n - 1 ))
(( idx >= ${#verdicts[@]} )) && idx=$(( ${#verdicts[@]} - 1 ))
case "${verdicts[idx]}" in
  APPROVE)
    printf 'No material defects remain.\n\nVERDICT: APPROVE\n' ;;
  APPROVE_REMARKS)
    printf 'No material defects remain.\n\nNon-blocking remarks:\n1. Mock nitpick one.\n2. Mock nitpick two.\n\nVERDICT: APPROVE\n' ;;
  REVISE)
    printf '1. Mock objection: the spec omits X, material because Y; add Z.\n\nVERDICT: REVISE\n' ;;
  NONE)
    printf 'Rambling critique with no verdict line.\n' ;;
  *)
    echo "mock claude: unknown verdict token '${verdicts[idx]}'" >&2; exit 64 ;;
esac
